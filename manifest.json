{
  "manifest_version": 3,
  "name": "Partial Width Side Panel",
  "description": "A Chrome extension that opens a partial-width UI and saves the current tab URL to Google Sheets.",
  "version": "1.0.0",
  "permissions": ["sidePanel", "storage", "identity", "tabs"],
  "host_permissions": ["https://sheets.googleapis.com/*"],
  "oauth2": {
    "client_id": "108437512115-iausj1t605gufdu483khs6cij99db446.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "action": {
    "default_title": "Open Partial Width Panel",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}